# Copy this file to .env.local for local dev.
# In production these are set in the Vercel dashboard under Environment Variables.

# Vercel Blob — auto-populated when you connect a Blob store to the project in Vercel
BLOB_READ_WRITE_TOKEN=

# Neon Postgres — auto-populated when you connect the Neon database in Vercel
DATABASE_URL=

# Passwords (choose your own strong passwords)
ADMIN_PASSWORD=your_admin_password_here
VIEWER_PASSWORD=your_viewer_password_here

# Secret for JWT session tokens (generate a random 32+ char string)
JWT_SECRET=your_random_secret_here_make_it_long_and_random
