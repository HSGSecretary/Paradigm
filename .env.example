# Copy this file to .env.local and fill in values
# These are also set in Vercel dashboard under Environment Variables

# Vercel Blob - auto-populated when you connect Blob storage in Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# Vercel Postgres - auto-populated when you connect a Postgres DB in Vercel dashboard
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Passwords (choose your own strong passwords)
ADMIN_PASSWORD=your_admin_password_here
VIEWER_PASSWORD=your_viewer_password_here

# Secret for JWT session tokens (generate a random 32+ char string)
JWT_SECRET=your_random_secret_here_make_it_long_and_random
